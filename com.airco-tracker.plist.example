<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.airco-tracker</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PROJECT_DIR__/.venv/bin/airco-tracker</string>
    <string>check</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>
  <key>StartInterval</key>
  <integer>600</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/tracker.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/tracker.err.log</string>
</dict>
</plist>
