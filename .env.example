# Local mode (Azure overrides these with Container Apps environment variables).
APP_ENV=local
EMAIL_BACKEND=smtp
STATE_BACKEND=local

# Email destination for local/direct mode only. Production resolves the
# current address from the sharded alert-recipient projection.
EMAIL_TO=you@example.com

# Email language: zh (Chinese, default), nl (Dutch), en (English), or fr (French).
EMAIL_LANG=zh

# SMTP example for Gmail. Use an app password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=replace-with-app-password
EMAIL_FROM=you@gmail.com

# Optional filters. Leave empty to disable.
MAX_PRICE_EUR=1500
MIN_BTU=7000

# Send one immediate message for products already available on the first run.
ALERT_ON_FIRST_SEEN=true

# Network settings
REQUEST_TIMEOUT_SECONDS=25

# Optional when invoking the command from outside the project directory:
# AIRCO_TRACKER_HOME=/Users/your-name/airco-tracking

# Azure mode — normally populated by infra/job.bicep, not by hand.
# EMAIL_BACKEND=azure_communication
# STATE_BACKEND=azure_blob
# ACS_ENDPOINT=https://your-resource.communication.azure.com
# AZURE_STORAGE_ACCOUNT_URL=https://your-account.blob.core.windows.net
# AZURE_STORAGE_CONTAINER=airco-tracker
# AZURE_STORAGE_BLOB=state.json
# AZURE_INVENTORY_BLOB=inventory.json
# AZURE_CLIENT_ID=<user-assigned-managed-identity-client-id>
# EMAIL_FROM=DoNotReply@xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.azurecomm.net

# Azure asynchronous alert pipeline (normally populated by infra/job.bicep).
# ALERT_DISPATCH_BACKEND=service_bus
# SERVICE_BUS_NAMESPACE=your-namespace.servicebus.windows.net
# STOCK_EVENTS_TOPIC=stock-events
# STOCK_EVENTS_SUBSCRIPTION=email-fanout
# FANOUT_JOBS_QUEUE=email-fanout-jobs
# EMAIL_JOBS_QUEUE=email-jobs
# AUTH_USERS_TABLE=users
# ALERT_OUTBOX_TABLE=alertoutbox
# ALERT_RECIPIENTS_TABLE=alertrecipients
# ALERT_DELIVERIES_TABLE=alertdeliveries
# ALERT_RECIPIENT_SHARDS=32
# ALERT_RECIPIENT_PAGE_SIZE=250
# ALERT_EVENT_MAX_AGE_SECONDS=21600
# ALERT_OUTBOX_RETENTION_DAYS=30
# ALERT_DELIVERY_RETENTION_DAYS=90
# EMAIL_MIN_SEND_INTERVAL_SECONDS=13
# SCANNER_LEASE_SECONDS=480
# DEPLOYMENT_PAUSED=false  # deploy-script maintenance switch, not a runtime secret

# Optional Key Vault hydration for third-party credentials. Managed Identity is used.
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net
# KEY_VAULT_SECRET_MAP=PARTNER_API_KEY=partner-api-key

# Optional Awin Trotec FR Link Builder integration. Trotec's first-party search
# remains the only live stock source; generated links are cached for one day.
# The publisher API token is injected through Key Vault in production.
# AWIN_PUBLISHER_API_TOKEN=

# AliExpress Affiliate Open Platform (catalogue/SKU inspection). These values
# are injected from Key Vault in production and must never be committed. The
# integration remains fail-closed and is not registered as a live stock source
# until an explicit SKU orderability/inventory signal has been verified.
# ALIEXPRESS_APP_KEY=
# ALIEXPRESS_APP_SECRET=
# ALIEXPRESS_TRACKING_ID=
