# Local mode (Azure overrides these with Container Apps environment variables).
APP_ENV=local
EMAIL_BACKEND=smtp
STATE_BACKEND=local

# Email destination
EMAIL_TO=you@example.com

# Email language: zh (Chinese, default), nl (Dutch), or en (English).
EMAIL_LANG=zh

# SMTP example for Gmail. Use an app password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=replace-with-app-password
EMAIL_FROM=you@gmail.com

# Optional filters. Leave empty to disable.
MAX_PRICE_EUR=1500
MIN_BTU=7000

# Send one immediate message for products already available on the first run.
ALERT_ON_FIRST_SEEN=true

# Network settings
REQUEST_TIMEOUT_SECONDS=25

# Optional when invoking the command from outside the project directory:
# AIRCO_TRACKER_HOME=/Users/your-name/airco-tracking-nl

# Azure mode — normally populated by infra/job.bicep, not by hand.
# EMAIL_BACKEND=azure_communication
# STATE_BACKEND=azure_blob
# ACS_ENDPOINT=https://your-resource.communication.azure.com
# AZURE_STORAGE_ACCOUNT_URL=https://your-account.blob.core.windows.net
# AZURE_STORAGE_CONTAINER=airco-tracker
# AZURE_STORAGE_BLOB=state.json
# AZURE_INVENTORY_BLOB=inventory.json
# AZURE_CLIENT_ID=<user-assigned-managed-identity-client-id>
# EMAIL_FROM=DoNotReply@xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.azurecomm.net

# Optional Key Vault hydration for third-party credentials. Managed Identity is used.
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net
# KEY_VAULT_SECRET_MAP=EMAIL_TO=notification-email
